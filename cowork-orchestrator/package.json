{
  "name": "cowork-orchestrator",
  "version": "2.0.0",
  "description": "Thin orchestration layer on Claude Agent SDK - parallel multi-agent task execution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cowork": "dist/cli/cowork.js",
    "cowork-mcp": "dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/cowork.ts",
    "cowork": "node dist/cli/cowork.js",
    "mcp": "node dist/mcp/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts"
  },
  "keywords": [
    "orchestrator",
    "claude",
    "agent-sdk",
    "multi-agent"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.49",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^12.6.2",
    "eventemitter3": "^5.0.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
